# ============================================
# HEXAA CLINIC VOICE AGENT - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local for local development
# For Render deployment, set these in Render Dashboard > Environment

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string (Render will provide this automatically)
DATABASE_URL=postgresql+asyncpg://username:password@host:port/database

# ============================================
# LIVEKIT CONFIGURATION
# ============================================
# LiveKit WebSocket URL (e.g., wss://your-project.livekit.cloud)
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# LiveKit API credentials (from LiveKit dashboard)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ============================================
# AI SERVICE API KEYS
# ============================================
# OpenAI API key (for GPT-4 language model)
OPENAI_API_KEY=your_openai_api_key

# ElevenLabs API key (for realistic text-to-speech)
ELEVEN_LABS=your_elevenlabs_api_key

# Deepgram API key (for speech-to-text transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# ============================================
# OPTIONAL CONFIGURATION
# ============================================
# Disable inference executor (automatically set for Linux/Windows)
# LIVEKIT_AGENT_INFERENCE_EXECUTOR_DISABLED=1